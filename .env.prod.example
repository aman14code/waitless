# Production Environment Variables
# Copy this file to .env.prod and fill in your values

# Database Configuration
POSTGRES_USER=waitless
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=waitless_db

# Backend Configuration
NODE_ENV=production
PORT=5000
DATABASE_URL=postgresql://waitless:your_secure_password_here@postgres:5432/waitless_db
JWT_SECRET=your_super_secure_jwt_secret_at_least_32_characters_long
CLIENT_URL=https://yourdomain.com

# Frontend Configuration
NEXT_PUBLIC_API_URL=https://yourdomain.com

# SSL Configuration (for nginx)
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# Redis Configuration (optional, for session storage)
REDIS_URL=redis://redis:6379

# Monitoring (optional)
SENTRY_DSN=your_sentry_dsn_here

# Email Configuration (optional, for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
